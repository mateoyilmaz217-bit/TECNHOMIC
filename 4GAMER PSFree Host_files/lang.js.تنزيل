/* ============================================================ */
/* 1.4 — محرك الاستبدال (applyLanguage Engine)                  */
/* ============================================================ */

function applyLanguage(lang) {
    try {
        if (!localeData[lang]) { lang = 'ar'; }
        var dict = localeData[lang];
        var dir  = (lang === 'ar') ? 'rtl' : 'ltr';

        document.documentElement.setAttribute('data-lang', lang);
        document.documentElement.setAttribute('dir', dir);
        localStorage.setItem('ui_lang', lang);

        var els = document.querySelectorAll('[data-i18n]');
        var i = 0;
        for (i = 0; i < els.length; i++) {
            var el  = els[i];
            var key = el.getAttribute('data-i18n');
            var val = dict[key];
            if (val === undefined) { continue; }

            var attrList = el.getAttribute('data-i18n-attr');
            if (attrList) {
                var attrs = attrList.split(',');
                var j = 0;
                for (j = 0; j < attrs.length; j++) {
                    el.setAttribute(attrs[j].trim(), val);
                }
            } else {
                el.innerHTML = val;
            }
        }

        if (typeof rebuildDynamicContent === 'function') {
            rebuildDynamicContent();
        }
        rebuildChangelog();
    } catch(e) { /* صامت */ }
}

function toggleLanguage() {
    try {
        var current = localStorage.getItem('ui_lang') || 'ar';
        var next    = (current === 'ar') ? 'en' : 'ar';
        applyLanguage(next);
    } catch(e) { /* صامت */ }
}

/* ============================================================ */
/* 1.6.2 — القارئ الحي t(key)                                   */
/* ============================================================ */

function t(key) {
    try {
        var lang = localStorage.getItem('ui_lang') || 'ar';
        var dict = (localeData && localeData[lang]) ? localeData[lang] : null;
        if (dict && dict[key] !== undefined) { return dict[key]; }
    } catch(e) {}
    return key;
}

