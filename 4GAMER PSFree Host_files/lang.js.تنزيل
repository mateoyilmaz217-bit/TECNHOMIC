/* تطبيق اللغة الافتراضية عند جاهزية DOM                       */
/* ============================================================ */

document.addEventListener('DOMContentLoaded', function() {
    var lang = localStorage.getItem('ui_lang') || 'ar';
    applyLanguage(lang);
});

